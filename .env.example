# Supabase Configuration
# Required by root-level scripts (setup-db.js, test-scenarios.js, generate-test-parties.js, scripts/*)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (used by setup-db.js and test-scenarios.js)
# Get this from Supabase Dashboard → Settings → API → service_role key
# WARNING: This key bypasses RLS. Never commit it or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
