generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String   @id @default(cuid())
  email                      String   @unique
  name                       String?
  username                   String?  @unique
  bio                        String?
  profilePictureUrl          String?
  instagram                  String?
  twitter                    String?
  youtube                    String?
  tiktok                     String?
  linkedin                   String?
  website                    String?
  defaultDietaryRestrictions String[]
  defaultLikedToppings       String[]
  defaultDislikedToppings    String[]
  defaultLikedBeverages      String[]
  defaultDislikedBeverages   String[]
  defaultAddress             String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  parties      Party[]
  orders       Order[]
  magicLinks   MagicLink[]
  apiKeys      ApiKey[]
  aiPhoneCalls AIPhoneCall[]
}

model Party {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String
  inviteCode         String    @unique @default(cuid()) @map("invite_code")
  customUrl          String?   @unique @map("custom_url")
  date               DateTime? @db.Timestamptz
  endTime            DateTime? @map("end_time") @db.Timestamptz
  duration           Float?
  timezone           String?   @db.VarChar
  pizzaStyle         String    @default("new-york") @map("pizza_style")
  availableBeverages String[]  @map("available_beverages")
  availableToppings  String[]  @map("available_toppings")
  address            String?
  venueName          String?   @map("venue_name")
  venueStatus        String?   @map("venue_status")
  venueCapacity      Int?      @map("venue_capacity")
  venueCost          Decimal?  @map("venue_cost") @db.Decimal(10, 2)
  venuePointPerson   String?   @map("venue_point_person")
  venueContactName   String?   @map("venue_contact_name")
  venueContactEmail  String?   @map("venue_contact_email")
  venueContactPhone  String?   @map("venue_contact_phone")
  venueOrganization  String?   @map("venue_organization")
  venueWebsite       String?   @map("venue_website")
  venueNotes         String?   @map("venue_notes")
  maxGuests          Int?      @map("max_guests")
  hideGuests         Boolean   @default(false) @map("hide_guests")
  requireApproval    Boolean   @default(false) @map("require_approval")
  coHosts            Json      @default("[]") @map("co_hosts")
  selectedPizzerias  Json?     @map("selected_pizzerias")
  password           String?
  eventImageUrl      String?   @map("event_image_url")
  description        String?
  rsvpClosedAt       DateTime? @map("rsvp_closed_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Photo settings
  photosEnabled   Boolean @default(true) @map("photos_enabled")
  photosPublic    Boolean @default(true) @map("photos_public")
  photoModeration Boolean @default(false) @map("photo_moderation")

  // Party Kit settings
  kitEnabled  Boolean   @default(false) @map("kit_enabled")
  kitDeadline DateTime? @map("kit_deadline") @db.Date

  // Event type and tagging (for GPP and other special events)
  eventType  String?  @map("event_type")  // 'standard', 'gpp', 'private', etc.
  eventTags  String[] @default([]) @map("event_tags")  // Tags for filtering/grouping

  // Donation settings
  donationEnabled    Boolean   @default(false) @map("donation_enabled")
  donationGoal       Decimal?  @db.Decimal(10, 2) @map("donation_goal")
  donationMessage    String?   @map("donation_message")
  suggestedAmounts   Json      @default("[500, 1000, 2500, 5000]") @map("suggested_amounts") // cents
  donationRecipient     String?   @map("donation_recipient")
  donationRecipientUrl  String?   @map("donation_recipient_url")
  donationEthAddress    String?   @map("donation_eth_address")

  // Share-to-unlock settings
  shareToUnlock    Boolean  @default(false) @map("share_to_unlock")
  shareTweetText   String?  @map("share_tweet_text")

  // NFT settings
  nftEnabled              Boolean   @default(false) @map("nft_enabled")
  nftChain                String?   @map("nft_chain")

  // Music settings
  musicEnabled Boolean @default(false) @map("music_enabled")
  musicNotes   String? @map("music_notes")

  // Fundraising (Sponsor CRM)
  fundraisingGoal Decimal? @map("fundraising_goal") @db.Decimal(10, 2)

  // Budget settings
  budgetEnabled Boolean  @default(false) @map("budget_enabled")
  budgetTotal   Decimal? @map("budget_total") @db.Decimal(10, 2)

  // Report-specific fields
  reportRecap        String?   @map("report_recap")       // Host-written event summary
  reportVideoUrl     String?   @map("report_video_url")   // Link to party video
  reportPhotosUrl    String?   @map("report_photos_url")  // Link to raw photos/video
  flyerArtist        String?   @map("flyer_artist")       // Flyer artist credit

  // KPI tracking
  xPostUrl           String?   @map("x_post_url")         // Main X/Twitter post
  xPostViews         Int?      @map("x_post_views")       // X post view count
  farcasterPostUrl   String?   @map("farcaster_post_url") // Main Farcaster post
  farcasterViews     Int?      @map("farcaster_views")    // Farcaster view count
  lumaUrl            String?   @map("luma_url")           // Luma event URL
  lumaViews          Int?      @map("luma_views")         // Luma page views
  poapEventId        String?   @map("poap_event_id")      // POAP event ID
  poapMints          Int?      @map("poap_mints")         // POAP mint count
  poapMoments        Int?      @map("poap_moments")       // POAP moments count

  // Report settings
  reportPublished    Boolean   @default(false) @map("report_published")
  reportPublicSlug   String?   @unique @map("report_public_slug")

  // Pinned apps (for Apps Hub tab bar)
  pinnedApps  Json?   @default("[]") @map("pinned_apps")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  guests           Guest[]
  orders           Order[]
  photos           Photo[]
  partyKit         PartyKit?
  donations        Donation[]
  raffles          Raffle[]
  displays         Display[]
  staff            Staff[]
  performers       Performer[]
  venues           Venue[]
  sponsors         Sponsor[]
  budgetItems      BudgetItem[]
  socialPosts      SocialPost[]
  notableAttendees NotableAttendee[]
  aiPhoneCalls     AIPhoneCall[]

  @@map("parties")
}

model Guest {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  email               String?  @db.VarChar
  ethereumAddress     String?  @map("ethereum_address") @db.VarChar
  roles               String[]
  role                String?  // Single role for report chart: "dev", "designer", "artist", etc.
  mailingListOptIn    Boolean  @default(false) @map("mailing_list_opt_in")
  dietaryRestrictions String[] @map("dietary_restrictions")
  likedToppings       String[] @map("liked_toppings")
  dislikedToppings    String[] @map("disliked_toppings")
  likedBeverages      String[] @map("liked_beverages")
  dislikedBeverages   String[] @map("disliked_beverages")
  pizzeriaRankings    String[] @map("pizzeria_rankings")
  submittedAt         DateTime @default(now()) @map("submitted_at") @db.Timestamptz
  submittedVia        String   @default("link") @map("submitted_via")
  approved            Boolean? // null = pending, true = approved, false = declined

  // NFT minting fields
  nftTokenId         Int?      @map("nft_token_id")
  nftTransactionHash String?   @map("nft_transaction_hash")
  nftMintedAt        DateTime? @map("nft_minted_at") @db.Timestamptz

  // Guest-suggested pizzerias
  suggestedPizzerias Json @default("[]") @map("suggested_pizzerias")

  // Waitlist fields
  status            String   @default("CONFIRMED")
  waitlistPosition  Int?     @map("waitlist_position")
  promotedAt        DateTime? @map("promoted_at") @db.Timestamptz

  // Check-in fields
  checkedInAt DateTime? @map("checked_in_at") @db.Timestamptz
  checkedInBy String?   @map("checked_in_by")

  partyId String @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  pizzaMappings    GuestPizzaMapping[]
  photos           Photo[]
  donations        Donation[]
  raffleEntries    RaffleEntry[]
  raffleWins       RaffleWinner[]
  notableAttendees NotableAttendee[]

  @@map("guests")
}

// Social media posts about the event (for reports)
model SocialPost {
  id           String   @id @default(uuid()) @db.Uuid
  partyId      String   @map("party_id") @db.Uuid
  party        Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  platform     String   // "twitter", "farcaster", "instagram"
  url          String   // Full URL to the post
  authorHandle String?  @map("author_handle")

  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([partyId])
  @@map("social_posts")
}

// Notable attendees for event reports
model NotableAttendee {
  id        String   @id @default(uuid()) @db.Uuid
  partyId   String   @map("party_id") @db.Uuid
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  name      String   // Person or company name
  link      String?  // Optional link to profile/website
  guestId   String?  @map("guest_id") @db.Uuid
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([partyId])
  @@map("notable_attendees")
}

model Donation {
  id              String   @id @default(cuid())
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("usd")
  status          String   @default("pending") // pending, succeeded, failed, refunded
  paymentIntentId String?  @map("payment_intent_id")
  chargeId        String?  @map("charge_id")
  donorName       String?  @map("donor_name")
  donorEmail      String?  @map("donor_email")
  isAnonymous     Boolean  @default(false) @map("is_anonymous")
  message         String?

  // Crypto donation fields
  paymentMethod   String   @default("stripe") @map("payment_method") // "stripe" or "crypto"
  chainId         Int?     @map("chain_id")         // 1 = Ethereum, 8453 = Base
  tokenSymbol     String?  @map("token_symbol")     // "ETH", "USDC", etc.
  tokenAddress    String?  @map("token_address")    // null for native ETH
  txHash          String?  @map("tx_hash")          // on-chain tx hash
  walletAddress   String?  @map("wallet_address")   // donor's wallet

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  partyId String @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  guestId String? @map("guest_id") @db.Uuid
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@map("donations")
}

model Order {
  id              String   @id @default(cuid())
  provider        String
  externalOrderId String?
  pizzas          Json
  totalAmount     Decimal  @db.Decimal(10, 2)
  status          String   @default("pending")
  pizzeriaName    String
  pizzeriaAddress String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ML training metadata
  totalPizzas       Int?
  avgGuestsPerPizza Float?

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderItems    OrderItem[]
  guestMappings GuestPizzaMapping[]
  aiPhoneCall   AIPhoneCall?
}

// Individual pizza items in an order (for ML training)
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  pizzaIndex    Int       // Position in the order (1st pizza, 2nd pizza, etc.)
  size          String
  toppings      String[]
  isHalfAndHalf Boolean   @default(false)
  leftToppings  String[]
  rightToppings String[]
  priceEstimate Decimal?  @db.Decimal(10, 2)

  guestMappings GuestPizzaMapping[]
  createdAt     DateTime @default(now())
}

// Maps guests to their assigned pizzas (for ML training)
model GuestPizzaMapping {
  id String @id @default(cuid())

  guestId String
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  whichHalf          String? // 'left', 'right', or null for whole pizza
  satisfactionRating Int?    // 1-5 rating (optional feedback)

  createdAt DateTime @default(now())

  @@unique([guestId, orderItemId])
}

model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  code      String    @unique
  email     String
  expiresAt DateTime
  used      Boolean   @default(false)
  attempts  Int       @default(0)
  lockedAt  DateTime?
  createdAt DateTime  @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Public API Models
// ============================================

model ApiKey {
  id          String       @id @default(cuid())
  name        String       // Friendly name for the API key
  key         String       @unique // SHA-256 hash of the actual key
  keyPrefix   String       @map("key_prefix") // First 8 chars for identification (e.g., "rsvp_sk_a1b2")
  scopes      String[]     // Array of scopes: parties:read, parties:write, etc.
  rateLimit   Int          @default(500) @map("rate_limit") // Requests per hour
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz
  revoked     Boolean      @default(false)
  revokedAt   DateTime?    @map("revoked_at") @db.Timestamptz
  status      String       @default("pending") // pending, approved, rejected
  requestedAt DateTime     @default(now()) @map("requested_at") @db.Timestamptz
  approvedAt  DateTime?    @map("approved_at") @db.Timestamptz
  approvedBy  String?      @map("approved_by") // Admin user ID who approved
  lastUsedAt  DateTime?    @map("last_used_at") @db.Timestamptz
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  webhooks    Webhook[]
  apiRequests ApiRequest[]

  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  url       String   // Webhook endpoint URL
  secret    String   // Secret for HMAC-SHA256 signature
  events    String[] // Array of events: party.created, guest.registered, etc.
  active    Boolean  @default(true)
  failCount Int      @default(0) @map("fail_count") // Consecutive failures
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  apiKeyId String @map("api_key_id")
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  event        String   // Event type (e.g., party.created)
  payload      Json     // Payload sent to webhook
  status       String   @default("pending") // pending, success, failed
  statusCode   Int?     @map("status_code") // HTTP response code
  responseBody String?  @map("response_body") // Response from webhook
  attempts     Int      @default(0)
  lastAttempt  DateTime? @map("last_attempt") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  webhookId String  @map("webhook_id")
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

model ApiRequest {
  id           String   @id @default(cuid())
  method       String   // HTTP method (GET, POST, etc.)
  path         String   // Request path
  statusCode   Int      @map("status_code") // Response status code
  responseTime Int      @map("response_time") // Response time in ms
  ip           String?  // Client IP address
  userAgent    String?  @map("user_agent") // User agent string
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  apiKeyId String @map("api_key_id")
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_requests")
}

// ============================================
// Photo Gallery Models
// ============================================

model Photo {
  id           String    @id @default(uuid()) @db.Uuid
  partyId      String    @map("party_id") @db.Uuid
  party        Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Upload info
  url          String    // Supabase Storage public URL
  thumbnailUrl String?   @map("thumbnail_url") // Optional smaller version
  fileName     String    @map("file_name")
  fileSize     Int       @map("file_size") // In bytes
  mimeType     String    @map("mime_type")
  width        Int?
  height       Int?

  // Uploader info (can be guest or anonymous)
  uploadedBy     String? @map("uploaded_by") @db.Uuid // Guest ID if known
  uploaderName   String? @map("uploader_name") // Display name
  uploaderEmail  String? @map("uploader_email") // For tracking
  guest          Guest?  @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  // Organization
  caption   String?
  tags      String[] @default([])
  starred   Boolean  @default(false) // Host can star photos
  starredAt DateTime? @map("starred_at") @db.Timestamptz

  // Moderation
  status     String    @default("approved")
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz
  reviewedBy String?   @map("reviewed_by")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, createdAt])
  @@index([partyId, starred])
  @@index([partyId, status])
  @@map("photos")
}

// ============================================
// Party Kit Models
// ============================================

model PartyKit {
  id      String @id @default(uuid()) @db.Uuid
  partyId String @unique @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Kit Selection
  requestedTier String  @map("requested_tier") // basic, large, deluxe
  allocatedTier String? @map("allocated_tier") // What they actually get (may differ)

  // Shipping Info
  recipientName String  @map("recipient_name")
  addressLine1  String  @map("address_line1")
  addressLine2  String? @map("address_line2")
  city          String
  state         String?
  postalCode    String  @map("postal_code")
  country       String  @default("USA")
  phone         String?

  // Status: pending, approved, shipped, delivered, declined
  status         String    @default("pending")
  trackingNumber String?   @map("tracking_number")
  trackingUrl    String?   @map("tracking_url")

  // Notes
  notes      String? // Host notes/special requests
  adminNotes String? @map("admin_notes") // Internal notes

  // Dates
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz
  approvedAt  DateTime? @map("approved_at") @db.Timestamptz
  shippedAt   DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("party_kits")
}

// ============================================
// Raffle Widget Models
// ============================================

model Raffle {
  id              String    @id @default(uuid()) @db.Uuid
  partyId         String    @map("party_id") @db.Uuid
  party           Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)

  name            String    @db.VarChar(255)
  description     String?
  status          String    @default("draft") @db.VarChar(50) // draft, open, closed, drawn
  entriesPerGuest Int       @default(1) @map("entries_per_guest")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  prizes          RafflePrize[]
  entries         RaffleEntry[]
  winners         RaffleWinner[]

  @@index([partyId])
  @@map("raffles")
}

model RafflePrize {
  id          String    @id @default(uuid()) @db.Uuid
  raffleId    String    @map("raffle_id") @db.Uuid
  raffle      Raffle    @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  name        String    @db.VarChar(255)
  description String?
  imageUrl    String?   @map("image_url")
  quantity    Int       @default(1)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  winners     RaffleWinner[]

  @@index([raffleId])
  @@map("raffle_prizes")
}

model RaffleEntry {
  id        String   @id @default(uuid()) @db.Uuid
  raffleId  String   @map("raffle_id") @db.Uuid
  raffle    Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  guestId   String   @map("guest_id") @db.Uuid
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([raffleId, guestId])
  @@index([raffleId])
  @@index([guestId])
  @@map("raffle_entries")
}

model RaffleWinner {
  id        String    @id @default(uuid()) @db.Uuid
  raffleId  String    @map("raffle_id") @db.Uuid
  raffle    Raffle    @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  prizeId   String    @map("prize_id") @db.Uuid
  prize     RafflePrize @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  guestId   String    @map("guest_id") @db.Uuid
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  claimedAt DateTime? @map("claimed_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([raffleId])
  @@index([guestId])
  @@map("raffle_winners")
}

// ============================================
// Display Widget Models
// ============================================

model Display {
  id      String @id @default(uuid()) @db.Uuid
  partyId String @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Basic Info
  name String
  slug String

  // Content Configuration
  contentType   String @default("slideshow") @map("content_type") // slideshow, qr_code, event_info, photos, custom
  contentConfig Json   @default("{}") @map("content_config") // Type-specific settings

  // Display Settings
  rotationInterval Int     @default(10) @map("rotation_interval") // Seconds between slides
  backgroundColor  String  @default("#000000") @map("background_color")
  showClock        Boolean @default(false) @map("show_clock")
  showEventName    Boolean @default(true) @map("show_event_name")

  // Access Control
  isActive Boolean @default(true) @map("is_active")
  password String?

  // Analytics
  lastViewedAt DateTime? @map("last_viewed_at") @db.Timestamptz
  viewCount    Int       @default(0) @map("view_count")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([partyId, slug])
  @@index([partyId])
  @@map("displays")
}

// ============================================
// Staffing Widget Models
// ============================================

model Staff {
  id          String    @id @default(uuid()) @db.Uuid
  partyId     String    @map("party_id") @db.Uuid
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Staff info
  name        String
  email       String?
  phone       String?
  role        String    // Role/position (e.g., "Coordinator", "Door", "Bar", "DJ", etc.)

  // Status
  status      String    @default("invited") // invited, confirmed, declined, checked_in
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamptz
  checkedInAt DateTime? @map("checked_in_at") @db.Timestamptz

  // Notes
  notes       String?

  // Metadata
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, status])
  @@map("staff")
}

// ============================================
// Music/DJ Lineup Models
// ============================================

model Performer {
  id      String @id @default(uuid()) @db.Uuid
  partyId String @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Basic Info
  name  String                    // DJ/performer name
  type  String @default("dj")     // dj, live_band, solo, playlist
  genre String?                   // Music genre/style

  // Schedule
  setTime     String? @map("set_time")     // Time as string (e.g., "21:00")
  setDuration Int?    @map("set_duration") // Duration in minutes
  sortOrder   Int     @default(0) @map("sort_order")

  // Contact
  contactName  String? @map("contact_name")
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  instagram    String?
  soundcloud   String?

  // Status
  status String @default("confirmed") // pending, confirmed, cancelled

  // Logistics
  equipmentProvided Boolean @default(false) @map("equipment_provided")
  equipmentNotes    String? @map("equipment_notes")
  fee               Decimal? @db.Decimal(10, 2)
  feePaid           Boolean @default(false) @map("fee_paid")

  // Notes
  notes String?

  // Metadata
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, sortOrder])
  @@map("performers")
}

// ============================================
// Venue Model (for venue picker tool)
// ============================================

model Venue {
  id           String    @id @default(uuid()) @db.Uuid
  partyId      String    @map("party_id") @db.Uuid
  party        Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Venue info
  name         String
  address      String?
  website      String?
  capacity     Int?
  cost         Decimal?  @db.Decimal(10, 2)
  organization String?

  // Contact
  pointPerson   String?  @map("point_person")
  contactName   String?  @map("contact_name")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")

  // Status tracking
  status       String    @default("researching")  // researching, contacted, negotiating, confirmed, deposit_paid, paid_in_full, declined

  // Selection
  isSelected   Boolean   @default(false) @map("is_selected")

  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, isSelected])
  @@map("venues")
}

// ============================================
// Sponsor CRM Models
// ============================================

model Sponsor {
  id      String @id @default(uuid()) @db.Uuid
  partyId String @map("party_id") @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Basic Info
  name         String  // Sponsor/company name
  website      String? // Company website
  brandTwitter String? @map("brand_twitter") // Brand's X/Twitter handle

  // Contact Info
  pointPerson    String? @map("point_person") // Who's managing this relationship
  contactName    String? @map("contact_name") // Contact at the sponsor company
  contactEmail   String? @map("contact_email")
  contactPhone   String? @map("contact_phone")
  contactTwitter String? @map("contact_twitter") // Contact person's X/Twitter handle
  telegram       String? // Telegram handle

  // Pipeline Status: todo, asked, yes, billed, paid, stuck, alum, skip
  status String @default("todo")

  // Fundraising
  amount          Decimal? @db.Decimal(10, 2) // Contribution amount
  sponsorshipType String?  @map("sponsorship_type") // cash, in-kind, venue, pizza, drinks, other
  productService  String?  @map("product_service") // For non-monetary contributions

  // Assets (for confirmed sponsors)
  logoUrl String? @map("logo_url")

  // Tracking
  notes           String? // Communication history, notes
  lastContactedAt DateTime? @map("last_contacted_at") @db.Timestamptz

  // Metadata
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, status])
  @@index([partyId, createdAt])
  @@map("sponsors")
}

// ============================================
// Budget Models
// ============================================

model BudgetItem {
  id          String   @id @default(uuid()) @db.Uuid
  partyId     String   @map("party_id") @db.Uuid
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  name        String
  category    String
  cost        Decimal  @db.Decimal(10, 2)
  status      String   @default("pending")

  pointPerson String?  @map("point_person")
  notes       String?
  receiptUrl  String?  @map("receipt_url")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([partyId, category])
  @@map("budget_items")
}

model AIPhoneCall {
  id     String @id @default(cuid())
  callId String @unique // Bland AI call_id
  status String @default("initiated") // initiated, ringing, in_progress, completed, failed, no_answer

  // Call metadata
  pizzeriaPhone   String
  pizzeriaName    String
  customerName    String
  customerPhone   String
  fulfillmentType String // pickup, delivery
  deliveryAddress String?

  // Order details sent
  orderItems     String @default("[]") // JSON array as string
  estimatedTotal Int? // In cents

  // Extracted from call
  confirmedTotal Int? // Actual total from pizzeria (cents)
  estimatedTime  String? // "30-45 minutes"
  orderConfirmed Boolean @default(false)

  // Call artifacts
  transcript   String?
  summary      String?
  recordingUrl String?
  callDuration Int? // seconds

  // Timestamps
  callStartedAt DateTime?
  callEndedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  partyId String @db.Uuid
  party   Party  @relation(fields: [partyId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
