# scripts/outreach/.env.example
#
# Copy to scripts/outreach/.env and fill with real values from your
# ~/.claude/CLAUDE.md gdrive section. NEVER commit the real .env (it's
# covered by the root .gitignore '.env' rule but double-check before pushing).
#
# Google OAuth (for Sheets + Drive API access). Use the refresh-token flow.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# DATABASE_URL is read from backend/.env automatically when this file does not
# define it, so you usually don't need to set it here. Override only when
# pointing at a non-default database (e.g. a Supabase branch).
# DATABASE_URL=postgres://...
